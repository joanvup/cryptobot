# ==============================================================================
# CONFIGURACIÓN DEL EXCHANGE (BINANCE FUTURES USDT-M)
# ==============================================================================
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui
USE_TESTNET=True
# LÍMITE DE FUNDING RATE (0.01% es el estándar, 0.03% ya es caro)
MAX_FUNDING_RATE=0.03

# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS (POSTGRESQL)
# ==============================================================================
# Formato: postgresql://usuario:password@localhost:5432/nombre_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/cryptobot

# ==============================================================================
# LÓGICA DE OPERACIÓN Y CICLOS (RITMO DEL BOT)
# ==============================================================================
DEFAULT_TIMEFRAME=15m
DEFAULT_LEVERAGE=5
AUTO_TRADING=True
CYCLE_INTERVAL_SECONDS=300   # El bot busca entradas cada 5 minutos
MONITOR_INTERVAL_SECONDS=5   # El bot vigila el Stop Loss en vivo cada 5 segundos
RADAR_INTERVAL_SECONDS=30    # El dashboard visual se actualiza cada 30 segundos

# ==============================================================================
# SELECCIÓN DINÁMICA DE SÍMBOLOS (CALIDAD SOBRE CANTIDAD)
# ==============================================================================
USE_SCANNER=False
SCAN_TOP_N=10
MIN_VOLUME_24H=50000000
# Top 10 Monedas de Alta Liquidez para evitar ruido y manipulaciones
WHITELIST=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,LINKUSDT,LTCUSDT,DOTUSDT

# ==============================================================================
# GESTIÓN DE RIESGO INSTITUCIONAL (CRÍTICO)
# ==============================================================================
RISK_PER_TRADE_PERCENT=1.0
MAX_OPEN_TRADES=4
ATR_SL_MULTIPLIER=1.2    # SL Inicial a 1.2 ATR
ATR_TP_MULTIPLIER=3.0    # Take Profit

# ==============================================================================
# TRAILING STOP MULTI-FASE (PROTECCIÓN DINÁMICA INSTITUCIONAL)
# ==============================================================================
TRAILING_STOP_ENABLED=True
# FASE 1 (Break-Even): Si el precio avanza 1 ATR, el SL va a la Entrada.
TS_PHASE1_ACTIVATION_ATR=1.0

# FASE 2 (Trailing Normal): Si avanza 1.5 ATR, el SL lo persigue a 1.0 ATR de distancia.
TS_PHASE2_ACTIVATION_ATR=1.5
TS_PHASE2_DISTANCE_ATR=1.0

# FASE 3 (Trailing Agresivo): Si avanza 2.0 ATR, el SL se aprieta a 0.8 ATR de distancia.
TS_PHASE3_ACTIVATION_ATR=2.0
TS_PHASE3_DISTANCE_ATR=0.8

# ==============================================================================
# HIPERPARÁMETROS DE ESTRATEGIA TÉCNICA (FRANCOTIRADOR)
# ==============================================================================
RSI_PERIOD=14
RSI_OVERBOUGHT=70.0          # No comprar techos
RSI_OVERSOLD=30.0            # No vender pisos
EMA_FAST=20
EMA_SLOW=50
VOL_RELATIVE_THRESHOLD=1.3   # EXIGE un 30% más de volumen que la media para entrar

# ==============================================================================
# INTELIGENCIA ARTIFICIAL (FILTRO DE ALTA PROBABILIDAD)
# ==============================================================================
AI_CONFIDENCE_THRESHOLD=0.56 # Confianza mínima del 65% exigida a la IA para entrar
MODEL_PATH=models/xgboost_model.pkl
TRAINING_LIMIT_KLINES=50000  # Entrena con los últimos ~17 meses de historia